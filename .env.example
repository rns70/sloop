# Copy to .env and fill in. sloop reads these at runtime; never commit real keys.

# Backend HTTP/WS server port (curl target, Vite proxies /api here).
PORT=5174

# Vite dev server port for the web app.
PORT_WEB=5173

# Absolute or repo-relative path to the workspace sloop operates on.
# Defaults to the bundled sample workspace if unset.
SLOOP_WORKSPACE=fixtures/sample-workspace

# Console log verbosity: silent | error | warn | info | debug (default: info).
# info streams live cascade progress + agent output to the terminal; debug adds
# internal tracing (WS connects, stream lifecycle); warn/error/silent quiet it.
SLOOP_LOG_LEVEL=info

# --- Model providers (resolved via the registry in .sloop/config.md) ---
# Anthropic (Claude opus/sonnet/haiku) — Pi's built-in provider.
ANTHROPIC_API_KEY=
# Nebius AI Studio (OpenAI-compatible; hosts NVIDIA Nemotron and other open models).
NEBIUS_API_KEY=

# --- Assistant (the in-app conversational chatbot) ---
# Registry alias the assistant runs on (default: sonnet, then first alias).
SLOOP_ASSISTANT_MODEL=
# Max tool-calling rounds per assistant turn. Clamped to [1, 12]; default 12.
# Lower it (e.g. 4) if the assistant keeps chaining edits / hunting for issues.
SLOOP_ASSISTANT_MAX_ITERATIONS=
